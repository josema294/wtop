[Desktop Entry]
Name=Wtop
Comment=Web-based real-time system monitor
GenericName=System Monitor
Exec=sh -c 'wtop --localhost-only & sleep 1 && xdg-open http://127.0.0.1:3000'
Icon=wtop
Terminal=false
Type=Application
Categories=System;Monitor;
Keywords=monitor;system;cpu;gpu;memory;network;
StartupNotify=false
